# Nextcloud AWS Deployment Configuration
# Copy this file to deployment-config.env and fill in your values

# Stack Configuration
STACK_NAME="nextcloud-production"
REGION="us-east-1"

# Network Configuration
VPC_ID="vpc-xxxxxxxxx"
PRIVATE_SUBNET_IDS="subnet-xxxxx,subnet-yyyyy"
PUBLIC_SUBNET_IDS="subnet-aaaaa,subnet-bbbbb"

# Database Configuration
DB_PASSWORD="your-secure-database-password-min-16-chars"
DB_MIN_CAPACITY="0.5"
DB_MAX_CAPACITY="16"

# Application Configuration
ADMIN_PASSWORD="your-nextcloud-admin-password"
DOMAIN_NAME=""  # Optional: your-domain.com
CERTIFICATE_ARN=""  # Optional: arn:aws:acm:...

# Scaling Configuration
MIN_TASKS="2"
MAX_TASKS="10"
TASK_CPU="1024"
TASK_MEMORY="2048"
